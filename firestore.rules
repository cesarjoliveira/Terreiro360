rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function isAdmin() {
      return signedIn()
        && exists(userPath(request.auth.uid))
        && get(userPath(request.auth.uid)).data.role == "admin"
        && get(userPath(request.auth.uid)).data.status == "active";
    }

    function createsOwnBasicUser(userId) {
      return signedIn()
        && request.auth.uid == userId
        && request.resource.data.role == "basic"
        && request.resource.data.status == "active"
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.keys().hasOnly([
          "displayName",
          "email",
          "phone",
          "role",
          "status",
          "createdAt",
          "updatedAt"
        ]);
    }

    function ownsChild(childId) {
      return signedIn()
        && exists(/databases/$(database)/documents/children/$(childId))
        && get(/databases/$(database)/documents/children/$(childId)).data.userId == request.auth.uid;
    }

    match /config/{docId} {
      allow read, write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create: if isAdmin() || createsOwnBasicUser(userId);
      allow update: if isAdmin() || (
        signedIn()
        && request.auth.uid == userId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["displayName", "phone", "updatedAt"])
      );
      allow delete: if isAdmin();
    }

    match /children/{childId} {
      allow read: if isAdmin() || ownsChild(childId);
      allow create, update, delete: if isAdmin();
    }

    match /dues/{dueId} {
      allow read: if isAdmin() || ownsChild(resource.data.childId);
      allow write: if isAdmin();
    }

    match /payables/{docId} {
      allow read, write: if isAdmin();
    }

    match /receivables/{docId} {
      allow read, write: if isAdmin();
    }

    match /products/{docId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /sales/{docId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
